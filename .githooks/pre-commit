#!/bin/sh
# Block direct commits on the integration branch and enforce formatting.
# Enable with: make hooks  (sets core.hooksPath to .githooks)

branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
case "$branch" in
  main|master)
    echo "pre-commit: direct commits on '$branch' are blocked." >&2
    echo "  Start a feature branch:  git switch -c feat/<topic>" >&2
    echo "  (bypass once with:        git commit --no-verify)" >&2
    exit 1
    ;;
esac

if ! make fmt-check; then
  echo "pre-commit: code is not formatted. Run 'make fmt' and re-commit." >&2
  exit 1
fi
